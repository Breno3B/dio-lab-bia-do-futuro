# =============================================================================
# ClaraMente — configuração local
# =============================================================================

OLLAMA_HOST=http://localhost:11434

# Configuração recomendada para o hardware avaliado:
# - Intel Core i7-7500U
# - 15,51 GiB de RAM
# - NVIDIA GeForce 940MX
# - Pop!_OS 24.04 LTS
#
# qwen3:4b é o modelo padrão recomendado para esse equipamento.
# qwen3:8b pode ser usado para comparação de qualidade, com maior latência.
# gpt-oss:20b deve ser testado somente após avaliar memória e desempenho.
OLLAMA_MODEL=qwen3:4b

# Baixa variabilidade nas respostas financeiras.
OLLAMA_TEMPERATURE=0.2

# Margem para carregamento e geração local no hardware avaliado.
OLLAMA_TIMEOUT_SECONDS=180

# Limites para reduzir memória, latência e respostas excessivamente longas.
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=250
MAX_USER_MESSAGE_CHARS=2000

# Configuração da aplicação.
LOG_LEVEL=INFO

# O modo de raciocínio não é controlado por variável de ambiente.
# A configuração recomendada usa think=False em src/llm_client.py.
