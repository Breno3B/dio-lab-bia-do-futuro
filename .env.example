# Configuração do Ollama
OLLAMA_HOST=http://localhost:11434

# =============================================================================
# Modelos sugeridos para testes locais
# =============================================================================
#
# - Mais adequado ao hardware observado:
#   qwen3:4b
#
# - Melhor equilíbrio entre qualidade e uso de recursos:
#   qwen3:8b com modo de raciocínio desativado (think=False)
#
# A escolha definitiva deve considerar os resultados de qualidade, segurança,
# formato das respostas, latência e consumo de memória definidos em
# docs/04-metricas.md.
#
# Exemplos:
#
# OLLAMA_MODEL=qwen3:4b
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_MODEL=gpt-oss:20b
#
# =============================================================================

OLLAMA_MODEL=qwen3:4b
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=250
MAX_USER_MESSAGE_CHARS=2000

# Configuração da aplicação
LOG_LEVEL=INFO

# =============================================================================
# Modo de raciocínio
# =============================================================================
#       * O modo de raciocínio não é controlado por esta variável.
#       * A configuração recomendada utiliza think=False em src/llm_client.py.
# =============================================================================